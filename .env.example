# Example environment variables for deeplog-serving-analysis
# Copy this file to .env and update values locally.

# Kafka configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=deeplog

# Model and serving configuration
MODEL_PATH=model/deeplog.pt
BENTOML_SERVICE_NAME=deeplog_service
TRITON_MODEL_REPO=/models

# Docker / deployment
DOCKER_ENV=development
