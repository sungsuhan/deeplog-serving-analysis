# .env.example — 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-northeast-2

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_HDFS=deeplog-hdfs
KAFKA_TOPIC_BGL=deeplog-bgl

# ── 학습 / 데이터 ──────────────────────────────────────────────────────────────
DATASET=hdfs                        # hdfs | bgl
CKPT_DIR=model/checkpoints/hdfs     # 학습 완료 후 생성

# ── FastAPI (port 8000) ────────────────────────────────────────────────────────
# DATASET, CKPT_DIR 위 값을 그대로 사용

# ── BentoML (port 3000) ───────────────────────────────────────────────────────
BENTOML_MODEL_NAME=deeplog
BENTOML_MODEL_TAG=latest

# ── Triton (port 8001 서버 / 8002 래퍼) ──────────────────────────────────────
TRITON_URL=localhost:8001
MODEL_NAME=deeplog
MODEL_REPO=serving/triton/models
